Algoritmo CalculoComisiones
    // Definir las variables de entrada y salida
    Definir sueldo_base, venta1, venta2, venta3 Como Real
    Definir total_comisiones, sueldo_total Como Real
    
    // Entrada de datos
    Escribir "Ingrese el sueldo base del vendedor:"
    Leer sueldo_base
    
    Escribir "Ingrese el monto de la venta 1:"
    Leer venta1
    Escribir "Ingrese el monto de la venta 2:"
    Leer venta2
    Escribir "Ingrese el monto de la venta 3:"
    Leer venta3
    
    // Proceso
    // Calculamos el 10% de la suma de las tres ventas
    total_comisiones <- (venta1 + venta2 + venta3) * 0.10
    
    // Suma de comisiones al sueldo base
    sueldo_total <- sueldo_base + total_comisiones
    
    // Salida de resultados
    Escribir "Dinero obtenido por concepto de comisiones: $", total_comisiones
    Escribir "El total que recibirá en el mes es: $", sueldo_total
FinAlgoritmo
