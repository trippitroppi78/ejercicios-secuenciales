//CREAR UN PROGRAMA PARA QUE TE MUESTRE LA SUMA, RESTA, MULTIPLICACION Y DIVISION DE DOS NUMEROS
PROCESO PRIMARIA
 ESCRIBIR "DIGITE EL PRIMER NUMERO "
 LEER NUM1
 ESCRIBIR "DIGITE EL SEGUNDO NUMERO"
 LEER NUM2
 SUMA = NUM1 + NUM2
 RESTA = NUM1 - NUM2
 MULTIPLICACION = NUM1 * NUM2
 DIVISION = NUM1/NUM2
 ESCRIBIR "LA SUMA ES IGUAL A ", SUMA
 ESCRIBIR "LA RESTA ES IGUAL A ", RESTA
 ESCRIBIR "LA MULTIPLICACION ES IGUAL A ", MULTIPLICACION
 ESCRIBIR "LA DIVISION ES IGUAL A ", DIVISION
FINPROCESO
