Algoritmo CalculoRaices
	// Definir las variables
	Definir num, raizCuadrada, raizCubica Como Real
	
	// Entrada de datos
	Escribir "Ingrese un número para calcular sus raíces:"
	Leer num
	
	// Proceso
	// Para la raíz cuadrada elevar a (1/2)
	raizCuadrada <- RC(num)
	
	// Para la raíz cúbica elevamos el número a la potencia 1/3
	//  (1/3)
	raizCubica <- num ^ (1/3)
	
	// Salida de resultados
	Escribir "La raíz cuadrada de ", num, " es: ", raizCuadrada
	Escribir "La raíz cúbica de ", num, " es: ", raizCubica
FinAlgoritmo
