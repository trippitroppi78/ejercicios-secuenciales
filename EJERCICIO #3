// CREAR UN PROGRAMA PARA CALCULAR LA HIPOTENUSA DE UN TRIANGULO SEGUN LA MEDIDA DE SUS CATETOS
PROCESO HIPOTENUSA
  ESCRIBIR "PROGRAMA QUE CALCULA LA HIPOTENUSA "
  ESCRIBIR "."
  ESCRIBIR "."
  ESCRIBIR "DIGITE LA MEDIDA DEL CATETO1"
  LEER CATETO1
  ESCRIBIR " DIGITE LA MEDIDA DEL CATETO2"
  LEER CATETO2
 HIPOTENUSA = RAIZ(CATETO1^2 + CATETO2^2)
 ESCRIBIR " LA HIPOTENUSA ES IGUAL A ", HIPOTENUSA
FINPROCESO
